# =============================================================================
#  Agente WhatsApp — variables de entorno
#  Copiá este archivo a .env.local y completá los valores.
#  NUNCA subas .env.local al repo (ya está en .gitignore).
# =============================================================================

# ── Supabase (OBLIGATORIO) ───────────────────────────────────────────────────
# Dashboard de Supabase > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://TU-PROYECTO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=tu_anon_key_publica
# Service-role key: SOLO server-side. NUNCA exponer al cliente.
SUPABASE_SERVICE_ROLE_KEY=tu_service_role_key_secreta

# ── Sitio (OBLIGATORIO para redirects de OAuth) ──────────────────────────────
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth (login con Google): se configura en el Dashboard de Supabase,
# NO acá. Supabase Dashboard > Authentication > Providers > Google

# ── Motor de IA (OBLIGATORIO) ────────────────────────────────────────────────
# Proveedor del LLM: 'openrouter' (recomendado) u 'ollama' (local).
LLM_PROVIDER=openrouter

# OpenRouter (si LLM_PROVIDER=openrouter) — https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
# Modelo por default. Multimodal + barato: google/gemini-2.5-flash
# Más capaz: google/gemini-2.5-pro
OPENROUTER_MODEL=google/gemini-2.5-flash

# Ollama (solo si LLM_PROVIDER=ollama, para correr el modelo localmente)
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.1

# ── WhatsApp / Meta Cloud API (OPCIONAL para demo; el simulador no lo necesita) ─
# Guía completa de cómo obtener cada valor: ver META_WHATSAPP.md
# 1) Verify token: lo inventás vos; debe coincidir con el del webhook en Meta.
WHATSAPP_VERIFY_TOKEN=un_string_secreto_que_invento_yo
# 2) Phone Number ID del número de prueba (Meta > WhatsApp > API Setup).
WHATSAPP_TEST_PHONE_NUMBER_ID=
# 3) Access token. El de "API Setup" vence en 24h: usar un token PERMANENTE
#    de Usuario del Sistema (ver META_WHATSAPP.md §2).
WHATSAPP_TEST_ACCESS_TOKEN=

# ── Google Calendar (OPCIONAL — espeja los turnos en un calendario compartido) ─
# Service Account de Google Cloud. Compartí tu calendario con el email del SA
# (permiso "Hacer cambios en eventos") y pegá su ID abajo. Ver README.
GOOGLE_SA_CLIENT_EMAIL=mi-sa@mi-proyecto.iam.gserviceaccount.com
# Private key del SA. Mantené los \n literales si la pegás en una sola línea.
GOOGLE_SA_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# ID del calendario destino (Configuración del calendario > Integrar calendario).
GOOGLE_CALENDAR_ID=tu_calendario@group.calendar.google.com

# ── Cron de confirmaciones de turno (OPCIONAL) ───────────────────────────────
# Bearer secreto que protege /api/cron/confirmations. En Vercel: setear igual.
CRON_SECRET=un_secreto_largo_aleatorio
